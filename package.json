{
  "name": "project-management",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client",
    "start": "node server/index.js",
    "seed": "node server/seed.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
